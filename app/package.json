{
  "name": "report-farm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Report.Farm — autonomous farm + supply-chain intelligence SaaS, built on the AlphaGeo core (cloned/re-skinned from RWR/mvp)",
  "scripts": {
    "dev": "vite",
    "gen:role-pack": "node scripts/gen-role-pack.mjs",
    "prebuild": "node scripts/gen-role-pack.mjs",
    "build": "vite build",
    "preview": "vite preview --port 5174",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:nuke": "docker compose -f infra/docker-compose.yml down -v",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "seed:postgis": "node --env-file=.env.local scripts/seed-postgis.mjs",
    "seed:minio": "node --env-file=.env.local scripts/seed-minio.mjs",
    "seed": "npm run seed:postgis && npm run seed:minio",
    "api:dev": "node --env-file=.env.local api/server.mjs",
    "api:migrate": "node --env-file=.env.local api/v1/db/migrate.mjs",
    "migrate": "node --env-file=.env.local api/v1/db/migrate.mjs",
    "api:parity": "node --env-file=.env.local scripts/api-parity-check.mjs",
    "build-ds:parity": "node scripts/build-ds-parity-check.mjs",
    "audit:tenant": "node scripts/audit-tenant-id.mjs",
    "audit:coverage": "node scripts/audit-mutation-coverage.mjs",
    "qa:rls": "node --env-file=.env.local scripts/qa-rls.mjs",
    "qa:org": "node --env-file=.env.local scripts/qa-org.mjs",
    "qa:org-rollup": "node --env-file=.env.local scripts/qa-org-rollup.mjs",
    "qa:org-drilldown": "node --env-file=.env.local scripts/qa-org-drilldown.mjs",
    "smoke:rbac": "node --env-file=.env.local scripts/smoke-rbac-matrix.mjs",
    "smoke:all": "npm run audit:tenant && npm run smoke:rbac",
    "qa:s6a:socket": "node --env-file=.env.local scripts/qa-s6a-socket.mjs",
    "install:s6a": "npm install socket.io@4.7.5 socket.io-client@4.7.5 --save"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "socket.io-client": "^4.7.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vite-plugin-cesium": "^1.2.23"
  },
  "dependencies": {
    "@deck.gl/mapbox": "^9.3.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tanstack/react-query": "^5.62.0",
    "@tmcw/togeojson": "^7.0.0",
    "@xmldom/xmldom": "^0.9.5",
    "cesium": "^1.141.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "deck.gl": "^9.3.2",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "maplibre-gl": "^4.7.1",
    "minio": "^8.0.5",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "resend": "^4.0.0",
    "shpjs": "^6.1.0",
    "socket.io": "^4.7.5",
    "stripe": "^22.3.0",
    "tailwind-merge": "^2.5.5",
    "three": "^0.171.0",
    "zustand": "^5.0.2"
  }
}
