# ===== Brand / Public URLs =====
VITE_PUBLIC_HOST=https://report.farm
VITE_EMAIL_FROM=noreply@report.farm

# ===== Resend (transactional email) =====
RESEND_API_KEY=
EMAIL_FROM=noreply@report.farm
EMAIL_INTERNAL_TO=ops@report.farm

# ===== Mapillary (street view, optional) =====
VITE_MAPILLARY_KEY=

# ===== Cloudflare Turnstile (contact form CAPTCHA) =====
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
# Site key (public) is hard-coded in contact.html for now; replace with real one.
# If TURNSTILE_SECRET_KEY is unset the backend logs a warning and skips
# captcha verification (dev mode only — never deploy production without it).
TURNSTILE_SECRET_KEY=
